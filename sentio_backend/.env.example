# ─────────────────────────────────────────────────────────
#  Sentio Backend – Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────

# ── LLM API (required) ────────────────────────────────────
# Supported: Groq, Together AI, Anyscale, self-hosted vLLM / TGI
API_LLM_BASE_URL=https://api.groq.com/openai/v1
API_LLM_MODEL=llama3-8b-8192
API_LLM_KEY=your_api_key_here

# ── Firebase (optional – disabling just skips Firestore persistence) ──
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json
FIREBASE_PROJECT_ID=your_firebase_project_id

# ── Conversation memory ───────────────────────────────────
MEMORY_WINDOW=10

# ── CORS (comma-separated origins) ───────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ── Debug ─────────────────────────────────────────────────
# Set to true to see which safety-filter rules fire in logs
SAFETY_FILTER_DEBUG=false
